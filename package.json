{
  "name": "code-porter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run db:up && npm run db:migrate && npm run api:start",
    "api:start": "node --env-file-if-exists=.env --import=tsx apps/api/src/server.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "node --env-file-if-exists=.env --import=tsx apps/api/src/db/migrate.ts",
    "test": "vitest run",
    "test:integration": "npm run db:up && node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.16.0",
    "@types/yazl": "^3.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
