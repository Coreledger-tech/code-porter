{
  "name": "code-porter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run db:up && npm run db:migrate && npm run api:start",
    "api:start": "node --env-file-if-exists=.env --import=tsx apps/api/src/server.ts",
    "worker:start": "node --env-file-if-exists=.env --import=tsx apps/api/src/worker.ts",
    "pr-poller:start": "node --env-file-if-exists=.env --import=tsx apps/api/src/pr-poller.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "node --env-file-if-exists=.env --import=tsx apps/api/src/db/migrate.ts",
    "cleanup:workspaces": "node --env-file-if-exists=.env --import=tsx apps/api/src/ops/cleanup-workspaces.ts",
    "cleanup:evidence": "node --env-file-if-exists=.env --import=tsx apps/api/src/ops/cleanup-evidence.ts",
    "release:rc": "node --env-file-if-exists=.env --import=tsx scripts/release-rc.ts",
    "verify:ghcr": "node --env-file-if-exists=.env --import=tsx scripts/verify-ghcr.ts",
    "pilot:run": "node --env-file-if-exists=.env --import=tsx scripts/pilot-run.ts",
    "test": "vitest run",
    "test:integration": "npm run db:up && docker compose up -d minio && docker compose up minio-init && node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.998.0",
    "@aws-sdk/s3-request-presigner": "^3.998.0",
    "prom-client": "^15.1.3",
    "yazl": "^3.3.1"
  },
  "overrides": {
    "fast-xml-parser": "^5.3.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.16.0",
    "@types/yazl": "^3.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
