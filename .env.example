PORT=3000
POSTGRES_HOST_PORT=5544
DATABASE_URL=postgresql://code_porter:code_porter@localhost:5544/code_porter

WORKFLOW_RUNNER=inmemory
POLICY_DEFAULT_PATH=./policies/default.yaml
RUN_WORKER_POLL_MS=1000
RUN_WORKER_CONCURRENCY=1
RUN_JOB_LEASE_SECONDS=300
RUN_JOB_HEARTBEAT_SECONDS=30
RUN_JOB_BACKOFF_BASE_SECONDS=15
RUN_JOB_BACKOFF_MAX_SECONDS=300
PR_POLL_INTERVAL_MS=60000
PR_POLL_BATCH_SIZE=100
PR_POLL_TIMEOUT_MS=3000

WORKSPACE_ROOT=./workspaces
WORKSPACE_CLEANUP_POLICY=delete_on_success_keep_on_failure
WORKSPACE_TTL_DAYS=7

EVIDENCE_STORE_MODE=local
EVIDENCE_ROOT=./evidence
EVIDENCE_EXPORT_ROOT=./evidence-exports
EVIDENCE_KEEP_LOCAL_DISK=true
EVIDENCE_CACHE_TTL_DAYS=7
EVIDENCE_URL_MODE=signed
EVIDENCE_SIGNED_URL_TTL_SECONDS=3600

S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=code-porter-evidence
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

BASE_URL=http://localhost:3000
GITHUB_AUTH_MODE=pat
GITHUB_API_URL=https://api.github.com
SUMMARY_GITHUB_LOOKUP_TIMEOUT_MS=1500

# Optional
# ENABLE_DETERMINISTIC_REMEDIATOR=true
# GITHUB_TOKEN=ghp_xxx
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=12345678
# GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/codeporter_github_app.pem
